{
  "name": "fj-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter fj-site dev",
    "build": "pnpm --filter fj-site build",
    "preview": "pnpm --filter fj-site preview",
    "typecheck": "pnpm --filter fj-site typecheck",
    "test": "pnpm --filter fj-site test",
    "e2e": "pnpm --filter fj-site e2e",
    "gen:impl": "node scripts/gen-impl-js.mjs",
    "check:impl": "node scripts/check-impl-ports.mjs"
  },
  "devDependencies": {
    "ts-blank-space": "^0.9.0",
    "typescript": "^6.0.3"
  }
}
